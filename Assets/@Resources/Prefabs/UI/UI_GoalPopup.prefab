      m_Calls: []
  m_text: "\uD06C\uB798\uD504\uD1A4 \uC815\uAE00 \uBD80\uD2B8\uCEA0\uD504, \uB2E8
    4\uC77C\uAC04\uC758 \uC0DD\uC874\uAE30.\n\n\uB2F9\uC2E0\uC740 5\uBA85\uC758 \uD300\uC6D0\uC744
    \uC774\uB04C\uACE0\n\uAE30\uD68D, \uAC1C\uBC1C, \uC544\uD2B8 \uC138 \uAC00\uC9C0
    \uBD84\uC57C\uB97C \uC644\uC131\uD574\uC57C \uD569\uB2C8\uB2E4.\n\n\uD300\uC6D0\uB4E4\uC758
    \uCEE8\uB514\uC158\uC744 \uAD00\uB9AC\uD558\uBA70\n\uCD5C\uB300\uD55C \uB192\uC740
    \uC644\uC131\uB3C4\uB97C \uB2EC\uC131\uD558\uC138\uC694.\n\n\uCD5C\uC885 \uD3C9\uAC00\uB294
    \uAE30\uD68D / \uD074\uB77C / \uC544\uD2B8\n\uC138 \uC9C4\uD589\uB3C4\uC758 \uD3C9\uADE0\uC73C\uB85C
    \uACB0\uC815\uB429\uB2C8\uB2E4."
